# Copy to .env and fill in. .env is gitignored -- never commit real keys.
# Any OpenAI-compatible endpoint works: a hosted router or a self-hosted
# inference server. Leave LLM_API_KEY empty for no-auth LAN endpoints.

# Ionix internal cluster (DeepSeek-V4-Flash-DSpark, no key on LAN):
LLM_BASE_URL=http://192.168.0.247:8000/v1
LLM_API_KEY=
LLM_MODEL=dspark

# Hosted router example:
# LLM_BASE_URL=https://router.gateframe.ai/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gateframe/opus-4.7
